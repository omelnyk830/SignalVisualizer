<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SignalVisualizer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="400"
        x:Class="SignalVisualizer.Views.PacketLogWindow"
        x:DataType="vm:PacketLogViewModel"
        Title="Packet Log"
        Width="700" Height="400">

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4" Spacing="12">
            <Button Command="{Binding TogglePauseCommand}"
                    Content="{Binding IsPaused, Converter={x:Static vm:MainWindowViewModel.PauseConverter}}"
                    Width="80" HorizontalContentAlignment="Center" />
            <Button Command="{Binding ClearLogCommand}" Content="Clear" />
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding PacketCount, StringFormat='Packets: {0}'}" />
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding LastValue, StringFormat='Last: {0:F0}'}" />
        </StackPanel>

        <!-- Packet log -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding PacketLog}"
                 x:Name="PacketLogList"
                 FontFamily="Cascadia Mono,Consolas,Courier New"
                 FontSize="12"
                 Background="#1E1E1E"
                 Foreground="#00FF88" />

    </Grid>
</Window>