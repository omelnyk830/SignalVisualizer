<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SignalVisualizer.ViewModels"
        xmlns:views="using:SignalVisualizer.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="SignalVisualizer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SignalVisualizer">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">

        <!-- Status bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4" Spacing="12">
            <TextBlock VerticalAlignment="Center" FontWeight="Bold"
                       Text="{Binding DroneCount, StringFormat='Drones: {0}'}" />
            <TextBlock VerticalAlignment="Center" Foreground="Gray"
                       Text="Plug in a USB device to connect…"
                       IsVisible="{Binding !DroneCount}" />
        </StackPanel>

        <!-- Drone tabs — one per connected UAV -->
        <TabControl Grid.Row="1"
                    ItemsSource="{Binding Drones}"
                    SelectedItem="{Binding SelectedDrone}">
            <TabControl.ItemTemplate>
                <DataTemplate x:DataType="vm:DroneTabViewModel">
                    <TextBlock Text="{Binding TabHeader}" />
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate x:DataType="vm:DroneTabViewModel">
                    <views:DroneTabView />
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

    </Grid>
</Window>